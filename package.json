{
  "name": "proxy",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint"
  },
  "devDependencies": {
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "protobufjs": ">=8.2.0",
      "@protobufjs/utf8": ">=1.1.1",
      "follow-redirects": ">=1.16.0",
      "dompurify": ">=3.4.0",
      "axios": ">=1.15.2",
      "fast-uri": ">=3.1.2",
      "postcss": ">=8.5.10",
      "brace-expansion": ">=5.0.6",
      "minimatch@3>brace-expansion": "^1.1.12",
      "ws": ">=8.20.1"
    }
  }
}
