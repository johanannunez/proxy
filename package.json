{
  "name": "parcel",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "dev-login": "doppler run --project parcel --config dev -- node apps/web/scripts/dev-login.mjs",
    "dev-agent-bootstrap": "doppler run --project parcel --config dev -- node apps/web/scripts/bootstrap-dev-agent.mjs"
  },
  "devDependencies": {
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "protobufjs": ">=7.5.5",
      "follow-redirects": ">=1.16.0",
      "dompurify": ">=3.4.0"
    }
  }
}
